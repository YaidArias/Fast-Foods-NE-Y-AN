{
  "cleanUrls": false,
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/(.*)\\.html$", "dest": "/$1.html" },
    { "src": "/(.*)\\.css$", "dest": "/$1.css" },
    { "src": "/(.*)\\.js$", "dest": "/$1.js" },
    { "src": "/(.*)\\.png$", "dest": "/$1.png" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
